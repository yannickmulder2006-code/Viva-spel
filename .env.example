# =====================================================================
# .env.example
# =====================================================================
# Kopieer dit bestand naar ".env" en vul je eigen waarden in:
#
#   cp .env.example .env
#
# Het bestand ".env" wordt NOOIT meegestuurd naar GitHub (staat in
# .gitignore) — zo blijven je geheime sleutels privé.
# =====================================================================

# --- Supabase ---------------------------------------------------------
# Te vinden in je Supabase project: Settings -> API
# Gebruik de "service_role" key (NIET de "anon/public" key), zodat de app
# altijd bij de database kan, ook met Row Level Security aangezet.
SUPABASE_URL=https://jouwproject.supabase.co
SUPABASE_KEY=jouw-service-role-key

# --- Spotify (optioneel, maar aanbevolen) ------------------------------
# Aanmaken via https://developer.spotify.com/dashboard -> Create app
# Nodig om liedjes te kunnen opzoeken (titel/artiest/jaartal/hoesfoto).
SPOTIFY_CLIENT_ID=jouw-spotify-client-id
SPOTIFY_CLIENT_SECRET=jouw-spotify-client-secret

# --- Beveiliging beheerscherm --------------------------------------
# Kies een eigen pincode voor het beheerscherm (bv. 4-6 cijfers).
ADMIN_PIN=1234

# --- Spelinstellingen (optioneel, hebben standaardwaarden) -------------
APP_MIN_YEAR=1950
APP_MAX_YEAR=2025
APP_DEFAULT_ROUNDS=10
